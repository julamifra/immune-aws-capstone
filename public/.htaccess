<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirigir subdominio test a dominio principal (PRIORIDAD AL INICIO)
  RewriteCond %{HTTP_HOST} ^test\.ioamigo\.com$ [NC]
  RewriteRule ^(.*)$ https://ioamigo.com/$1 [L,R=301]

  # Forzar HTTPS y no-www
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.ioamigo\.com$ [NC]
  RewriteRule ^(.*)$ https://ioamigo.com/$1 [L,R=301]

  # BEGIN 301 Redirections

  # Redirecciones añadidas por revisión de URLs (bloque 1)
